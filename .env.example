# Configuration pour la Signature d'Extension Firefox
# ====================================================
#
# Pour signer votre extension localement avec `make sign`, vous devez :
#
# 1. Créer un compte sur https://addons.mozilla.org
# 2. Générer des clés API : https://addons.mozilla.org/developers/addon/api/key/
# 3. Copier ce fichier vers .env :
#    cp .env.example .env
# 4. Remplir les valeurs ci-dessous
# 5. Charger les variables :
#    source .env

# Clé API Mozilla (format: user:12345:67)
export WEB_EXT_API_KEY='your_api_key_here'

# Secret API Mozilla (longue chaîne alphanumérique)
export WEB_EXT_API_SECRET='your_api_secret_here'

# Note: Le fichier .env est ignoré par git pour des raisons de sécurité
# Ne commitez JAMAIS vos clés API !
