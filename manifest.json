{
  "manifest_version": 2,
  "name": "PentestHAR - Security Traffic Analyzer",
  "version": "2.0.0",
  "description": "Capture et analyse de sécurité du trafic réseau. Détection de secrets, IDOR, headers vulnérables. Export ffuf/nuclei/Burp.",
  "author": "venantvr-security",
  "homepage_url": "https://github.com/venantvr-security",

  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  },

  "permissions": [
    "devtools",
    "downloads",
    "storage",
    "notifications",
    "<all_urls>"
  ],

  "browser_specific_settings": {
    "gecko": {
      "id": "pentesthar@venantvr-security",
      "strict_min_version": "78.0"
    }
  },

  "incognito": "spanning",

  "devtools_page": "devtools/devtools.html",

  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },

  "browser_action": {
    "default_icon": {
      "48": "icons/icon-48.png"
    },
    "default_title": "PentestHAR",
    "default_popup": "popup/popup.html"
  },

  "options_ui": {
    "page": "options/options.html",
    "browser_style": true
  }
}
